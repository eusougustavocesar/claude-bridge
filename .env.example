# ===== Claude CLI =====

# Path to the `claude` CLI binary.
# Default ("claude") works if claude is on your PATH.
# Set the full path if needed: run `which claude` to find yours.
CLAUDE_BIN=claude

# Working directory where Claude Code runs (sandboxed).
# IMPORTANT: Claude reads/edits files inside this directory. Do NOT set it
# to your $HOME — any compromise of WhatsApp would expose your entire home.
# Default: local sandbox inside this repo.
CLAUDE_CWD=./workspace

# Path to an MCP config with empty `mcpServers`. Required so Claude's
# MCP startup doesn't hang when spawned as a subprocess of a headless
# daemon (no TTY). Leave as-is unless you know what you're doing.
CLAUDE_MCP_CONFIG=./empty-mcp.json

# Max seconds to wait for Claude to respond before killing the subprocess.
CLAUDE_TIMEOUT_SECONDS=180

# ===== Channel: WhatsApp =====

# JIDs allowed to chat with the bridge.
# Leave empty to only respond to your own self-chat messages.
# WhatsApp now uses LIDs (@lid) for privacy — include BOTH your phone JID
# (5548...@s.whatsapp.net) AND your device LID if you message yourself.
# Example: "5548999999999@s.whatsapp.net,123456789012345@lid"
ALLOWED_JIDS=

# ===== Session =====

# How Claude remembers context across messages:
#   "continue" = single rolling session (uses `claude --continue`)
#   "none"     = every message is independent (no memory)
SESSION_MODE=continue

# ===== Rate limiting =====

# Max messages per chat per window.
RATE_LIMIT_MAX=10

# Window in seconds.
RATE_LIMIT_WINDOW_SECONDS=60

# ===== Admin HTTP server =====

# Enable the local HTTP admin API (and the web UI if built).
# Bound to localhost only — never exposed to the network.
HTTP_ENABLED=true
HTTP_HOST=127.0.0.1
HTTP_PORT=3737

# ===== Notifications (POST /api/notify) =====

# WhatsApp JID that receives inbound webhook notifications.
# Leave empty to default to your own self-chat.
# Example: "5548999999999@s.whatsapp.net"
NOTIFY_JID=

# Bearer token to protect POST /api/notify from unauthorized callers.
# Leave empty to allow all local calls without auth.
# Example: "my-secret-token"
NOTIFY_TOKEN=

# ===== Audio transcription (v0.4) =====

# Enable voice message transcription via Whisper.
# Requires: pip install openai-whisper  (and ffmpeg in PATH)
AUDIO_ENABLED=false

# Path to the whisper binary. Defaults to "whisper" (must be on PATH).
# Run `which whisper` to find yours after installing.
WHISPER_BIN=whisper

# Whisper model size: tiny | base | small | medium | large
# "base" is a good default (~140 MB, fast, ~95% accuracy for clear speech).
WHISPER_MODEL=base

# Language hint for Whisper. Speeds up transcription and improves accuracy.
# Use ISO 639-1 codes: pt, en, es, fr, de, ...
# Leave empty for auto-detection.
WHISPER_LANGUAGE=pt

# ===== Image support (v0.4) =====

# Enable image processing via Claude's file-reading capability.
# Images are saved to CLAUDE_CWD/tmp/ and Claude reads them from there.
IMAGE_ENABLED=false

# How long (in seconds) to keep the image file in CLAUDE_CWD/tmp/ after
# Claude processes it. Shorter = less disk usage.
MEDIA_TMP_TTL_SECONDS=60

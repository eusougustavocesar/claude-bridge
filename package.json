{
  "name": "claude-bridge",
  "version": "0.1.0",
  "description": "Persistent bridge for Claude Code across messaging channels. Use Claude from WhatsApp even when your Mac is closed.",
  "private": false,
  "type": "module",
  "main": "dist/bot.js",
  "bin": {
    "claude-bridge": "dist/bot.js"
  },
  "scripts": {
    "dev": "tsx src/bot.ts",
    "build": "tsc",
    "start": "node dist/bot.js",
    "pair": "tsx src/bot.ts"
  },
  "keywords": [
    "claude-code",
    "claude",
    "whatsapp",
    "bridge",
    "baileys",
    "anthropic",
    "ai",
    "launchagent",
    "daemon"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/USER/claude-bridge.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

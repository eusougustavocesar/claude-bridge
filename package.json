{
  "name": "reverb",
  "version": "0.1.0",
  "description": "Connect your AI CLI to any messaging channel. Use Claude Code, Gemini CLI, or any AI assistant from WhatsApp even when your Mac is closed.",
  "private": false,
  "type": "module",
  "main": "dist/bot.js",
  "bin": {
    "reverb": "dist/bot.js"
  },
  "scripts": {
    "dev": "tsx src/bot.ts",
    "build": "tsc",
    "setup": "node scripts/setup.mjs",
    "start": "node dist/bot.js",
    "pair": "tsx src/bot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "reverb",
    "ai-cli",
    "whatsapp",
    "bridge",
    "baileys",
    "claude-code",
    "gemini-cli",
    "launchagent",
    "daemon"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eusougustavocesar/reverb.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@whiskeysockets/baileys": "^6.7.9",
    "croner": "^10.0.1",
    "grammy": "^1.42.0",
    "hono": "^4.12.14",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
